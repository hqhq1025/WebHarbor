# =============================================================
# Heavy assets — managed via Hugging Face dataset (see .assets-revision).
# Run `scripts/fetch_assets.sh` to download into the right places.
# =============================================================
sites/*/instance_seed/
sites/*/static/images/
sites/*/static/external_cache/

# =============================================================
# Intermediate / volatile — never committed anywhere.
# =============================================================
sites/*/scraped_data/      # scrape pipeline intermediate; runtime data lives in instance_seed/*.db
sites/*/instance/          # rebuilt at every container boot from instance_seed/
sites/*/venv/

# HF download metadata produced by `hf download`.
sites/.cache/
**/.cache/huggingface/

# HF dataset auto-artifacts that arrive together with the assets but belong
# to the bucket, not to this code repo.
sites/.gitattributes
sites/README.md

# =============================================================
# Python
# =============================================================
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
htmlcov/
dist/
build/
*.so

# =============================================================
# Virtual envs
# =============================================================
.venv/
venv/
env/

# =============================================================
# Editors / IDEs
# =============================================================
.idea/
.vscode/
*.swp
*.swo
*~
.*.un~

# =============================================================
# OS junk
# =============================================================
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini

# =============================================================
# Secrets / local config
# =============================================================
.env
.env.*
!.env.example
secrets.json
*.pem
*.key

# =============================================================
# Logs / temp
# =============================================================
*.log
*.tmp
*.bak

# =============================================================
# CI / build workspace
# =============================================================
.assets/

# ============================================================
# Agent demo results
# =============================================================
agent_demo/runs/